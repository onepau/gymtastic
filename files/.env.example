# Copy to .env and fill in. Never commit the real .env file.

ANTHROPIC_API_KEY=

# Cloudflare Vectorize + Workers AI (for vector store retrieval and embeddings)
# Token needs: Workers AI (run) + Vectorize (edit) permissions
# Create the index once: npx wrangler vectorize create gymtastic-kb --dimensions=384 --metric=cosine
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional overrides — sensible defaults are set in code
CLASSIFIER_MODEL=claude-sonnet-4-6
GUARDRAIL_MODEL=claude-haiku-4-5-20251001

# Rotate the PhotoShelter credential that was hardcoded in the old 05 Image embedding
# agent's instructions before using it here or anywhere else.
PHOTOSHELTER_USERNAME=
PHOTOSHELTER_PASSWORD=
